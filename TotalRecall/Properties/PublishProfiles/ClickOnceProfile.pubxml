<?xml version="1.0" encoding="utf-8"?>
<!--
  ClickOnce publish profile for TotalRecall (WinForms).
  Produces a self-contained .NET 10 install at TotalRecall\bin\publish\:
    setup.exe                            ← bootstrapper, the OneClick installer
    TotalRecall.application              ← deployment manifest
    publish.html                         ← landing page
    Application Files\TotalRecall_X_Y_Z\ ← the app + MCP server + tessdata
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>ClickOnce</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>

    <PublishDir>bin\publish\</PublishDir>
    <PublishUrl>bin\publish\</PublishUrl>
    <InstallUrl>https://github.com/ilyafainberg/TotalRecall/releases/latest/download/</InstallUrl>

    <ApplicationVersion>1.0.0.0</ApplicationVersion>
    <ApplicationRevision>0</ApplicationRevision>
    <MinimumRequiredVersion>1.0.0.0</MinimumRequiredVersion>

    <UpdateEnabled>true</UpdateEnabled>
    <UpdateRequired>false</UpdateRequired>
    <UpdateMode>Foreground</UpdateMode>
    <UpdatePeriodically>false</UpdatePeriodically>

    <PublisherName>Ilya Fainberg</PublisherName>
    <ProductName>TotalRecall</ProductName>
    <SuiteName>TotalRecall</SuiteName>

    <Install>true</Install>
    <InstallFrom>Web</InstallFrom>
    <BootstrapperEnabled>true</BootstrapperEnabled>
    <GenerateManifests>true</GenerateManifests>
    <SignManifests>false</SignManifests>

    <CreateWebPageOnPublish>true</CreateWebPageOnPublish>
    <WebPage>publish.html</WebPage>

    <CreateDesktopShortcut>true</CreateDesktopShortcut>
  </PropertyGroup>
</Project>
